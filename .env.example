# ─────────────────────────────────────────────────────────────
# ScopeSeal — environment variables
# Copy to `.env` and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Public app config
NEXT_PUBLIC_APP_NAME="ScopeSeal"
NEXT_PUBLIC_APP_URL="https://scopeseal.codezela.com"

# Database (NeonDB Postgres pooler URL).
# NOTE: remove `channel_binding=require` from the URL if present — Prisma's pg
# adapter does not support it. Keep `?sslmode=require`. Use the -pooler endpoint.
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require"

# Auth.js v5
AUTH_SECRET="generate-with: openssl rand -base64 32"
# Trusted host for Auth.js (production domain)
AUTH_TRUST_HOST="https://scopeseal.codezela.com"

# Encryption key for admin-stored provider API keys (32-byte hex = 64 chars).
# Generate with: openssl rand -hex 32
AI_ENCRYPTION_KEY=""

# Guest / rate limiting
GUEST_REPORT_QUOTA="3"
RATE_LIMIT_WINDOW_SECONDS="60"
RATE_LIMIT_MAX_REQUESTS="10"

# Optional: Upstash Redis for distributed rate limiting. If unset, in-memory
# limiter is used (single-instance only — fine for Vercel hobby/early traffic).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Optional: OpenAI-compatible provider DEFAULT (only used as a server-side
# fallback when no admin-configured provider exists). Leave unset to disable AI
# until an admin connects one in /admin.
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"
